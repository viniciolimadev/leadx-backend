APP_ENV=dev
APP_SECRET=change_me_to_a_random_32char_string
APP_DEBUG=true

# PostgreSQL
POSTGRES_DB=leadx_db
POSTGRES_USER=leadx
POSTGRES_PASSWORD=leadx_password
POSTGRES_PORT=5432

DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?serverVersion=16&charset=utf8"

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_to_a_strong_passphrase

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Nginx
NGINX_PORT=8080
